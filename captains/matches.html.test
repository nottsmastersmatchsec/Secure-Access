<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <title>Matches — Notts Masters Badminton</title>
  <meta name="viewport" content="width=device-width, initial-scale=1" />

  <style>
    body { margin: 0; font-family: system-ui, sans-serif; background: #f5f5f5; color: #222; }
    header { background: #0a1a33; color: white; padding: 20px; text-align: center; }
    nav { background: #13294b; display: flex; justify-content: center; flex-wrap: wrap; padding: 10px 0; }
    nav a { color: white; text-decoration: none; margin: 8px 15px; font-weight: 600; }
    nav a:hover { text-decoration: underline; }

    .container {
      max-width: 1000px;
      margin: 40px auto;
      padding: 0 20px 40px;
      text-align: center;
    }

    .logged-in-banner {
      background: #e8f4ff;
      padding: 12px 15px;
      margin: 20px auto;
      max-width: 600px;
      border-radius: 6px;
      font-weight: 600;
      color: #0a1a33;
    }

    iframe {
      width: 100%;
      height: 800px;
      border: 0;
      border-radius: 10px;
      background: white;
    }

    .back-button {
      display: inline-block;
      margin: 25px auto 0;
      padding: 12px 20px;
      background: #13294b;
      color: white;
      text-decoration: none;
      font-weight: 600;
      border-radius: 8px;
    }
    .back-button:hover { background: #0a1a33; }

    .error-box {
      max-width: 500px;
      margin: 40px auto;
      padding: 25px;
      background: white;
      border-radius: 12px;
      box-shadow: 0 6px 16px rgba(0,0,0,0.12);
      text-align: center;
      color: #c62828;
      font-size: 1.1rem;
      font-weight: 600;
    }

    footer {
      margin-top: 20px;
      padding: 20px;
      text-align: center;
      background: #0a1a33;
      color: white;
    }
  </style>
</head>

<body>

<header>
  <h1>Notts Masters Badminton</h1>
  <p>Matches — Captains & Selectors Area</p>
</header>

<div id="nav"></div>
<script>
  fetch("/Home/nav.html")
    .then(r => r.text())
    .then(html => document.getElementById("nav").innerHTML = html);
</script>

<div class="container" id="content">
  <h2>Loading Matches Sheet…</h2>
  <p>Please wait.</p>
</div>

<footer>
  © Notts Masters Badminton — Matches
</footer>

<script>
  // Load session
  const raw = localStorage.getItem("clubSession");

  // Not logged in → send to login
  if (!raw) {
    window.location.href = "/Home/login/login.html?redirect=captains";
  }

  let session;
  try { session = JSON.parse(raw); }
  catch {
    localStorage.removeItem("clubSession");
    window.location.href = "/Home/login/login.html?redirect=captains";
  }

  // Must be logged in
  if (!session || !session.loggedIn) {
    window.location.href = "/Home/login/login.html?redirect=captains";
  }

  // Must be captain or selector
  const role = (session.captain_selector || "").toLowerCase();
  if (role !== "captain" && role !== "selector") {
    document.getElementById("content").innerHTML = `
      <div class="error-box">
        ❌ You do not have permission to access this page.
      </div>
    `;
    throw new Error("Access denied");
  }

  // If allowed → show sheet
  document.getElementById("content").innerHTML = `
    <div class="logged-in-banner">
      ✅ Logged in as ${session.firstname} ${session.surname} (${session.captain_selector})
    </div>

    <iframe src="https://docs.google.com/spreadsheets/d/1MomVFN0gpfM_bYldQ5Df9CjwOkYRGOMSGtmv2PWyMiw/edit?gid=0#gid=0"></iframe>

    <a href="/Home/captains/access.html" class="back-button">⬅ Back to Captains & Selectors Area</a>
  `;
</script>

</body>
</html>
